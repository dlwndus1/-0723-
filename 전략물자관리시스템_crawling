import time
import pandas as pd

from selenium import webdriver
from selenium.webdriver.common.by import By


driver = webdriver.Chrome()

url = "https://www.yestrade.go.kr/hsk-control-search"
driver.get(url)

time.sleep(3)


data = []

total_page = 2040


for page in range(1, total_page + 1):

    rows = driver.find_elements(
        By.CSS_SELECTOR,
        "#hsk-control-list-tbody tr"
    )

    for row in rows:

        columns = row.find_elements(By.TAG_NAME, "td")

        data.append([
            columns[0].text.strip(),
            columns[1].text.strip(),
            columns[2].text.strip(),
            columns[3].text.strip()
        ])

    print(f"{page}페이지 수집 완료")

    if page < total_page:

        next_button = driver.find_element(
            By.XPATH,
            "//div[contains(@class, 'page-number') and contains(text(), '다음')]"
        )

        driver.execute_script(
            "arguments[0].click();",
            next_button
        )

        time.sleep(1)


driver.quit()


df = pd.DataFrame(
    data,
    columns=[
        "품목분류(HS)",
        "HSK품목명",
        "HSK영문명",
        "통제번호"
    ]
)

df.to_csv(
    "전략물자_이중용도.csv",
    index=False,
    encoding="utf-8-sig"
)

display(df.head())
print("수집 건수:", len(df))
